# PRODUCTION environment (separate Supabase project from staging/test).
# Copy to .env.prod (gitignored) and fill in. Used only by the *:prod scripts
# you run locally for the production migrate/backfill. The live app reads these
# from Vercel's Production env vars, not from this file.

# Production Supabase — Transaction pooler (port 6543), for the app/backfill:
DATABASE_URL="postgresql://postgres.<prod-ref>:[PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Production Supabase — session connection (port 5432), for migrations:
DIRECT_URL="postgresql://postgres.<prod-ref>:[PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Production Google (your live service account + live sheets):
GOOGLE_CREDENTIALS=<one-line production service-account JSON>
SPREADSHEET_ID=<production orders/products spreadsheet id>
PRICING_SPREADSHEET_ID=<production חישוב מחירים spreadsheet id>

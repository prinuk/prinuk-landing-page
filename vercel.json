{
  "functions": {
    "api/order.js": {
      "maxDuration": 60
    },
    "api/price-list.js": {
      "maxDuration": 60
    },
    "api/dashboard.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/team",
      "has": [{ "type": "host", "value": "order.prinuk.co.il" }],
      "dest": "/team/index.html"
    },
    {
      "src": "/team",
      "has": [{ "type": "host", "value": "test.order.prinuk.co.il" }],
      "dest": "/team/index.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "order.prinuk.co.il" }],
      "dest": "/order/index.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "test.order.prinuk.co.il" }],
      "dest": "/order/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/team",
      "has": [{ "type": "host", "value": "order.prinuk.co.il" }],
      "destination": "/team/index.html"
    },
    {
      "source": "/team",
      "has": [{ "type": "host", "value": "test.order.prinuk.co.il" }],
      "destination": "/team/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "order.prinuk.co.il" }],
      "destination": "/order/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "test.order.prinuk.co.il" }],
      "destination": "/order/index.html"
    },
    {
      "source": "/:path((?!api/|order/|team/|assets/|_vercel/).*)",
      "has": [{ "type": "host", "value": "order.prinuk.co.il" }],
      "destination": "/order/:path*"
    },
    {
      "source": "/:path((?!api/|order/|team/|assets/|_vercel/).*)",
      "has": [{ "type": "host", "value": "test.order.prinuk.co.il" }],
      "destination": "/order/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
